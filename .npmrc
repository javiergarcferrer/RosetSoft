; @google/model-viewer 4.x declares a peer of three@^0.183 while the app tracks
; three@^0.184 (a single minor ahead). model-viewer ships its OWN bundled three
; in its published dist, so the runtime is unaffected — this only relaxes npm's
; peer RESOLVER so install succeeds locally and on Vercel. Pinned versions are
; untouched (the lockfile still governs what actually installs).
legacy-peer-deps=true
